{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "vitest.config.ts",
    "vitest.bench.config.ts",
    "tsup.config.ts"
  ],
  "exclude": ["node_modules", "dist", "src.legacy", ".tmp"]
}
